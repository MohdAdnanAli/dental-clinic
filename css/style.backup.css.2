  border-radius: 0.5rem; 
  font-size: 0.9rem; 
  font-weight: 600; 
  letter-spacing: 1px; 
  text-transform: uppercase; 
  cursor: pointer; 
  text-decoration: none; 
  transition: var(--transition); 
  display: inline-flex; 
  align-items: center; 
  gap: var(--space-xs); 
  min-height: 3rem; 
  width: 100%; 
