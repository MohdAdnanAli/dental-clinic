  font-family: 'Cormorant Garamond', serif; 
  color: var(--navy); 
  line-height: 1; 
  margin-bottom: var(--space-xs);
}

.stat-label { 
  font-size: 0.85rem; 
  color: var(--text-muted); 
  letter-spacing: 1px; 
  text-transform: uppercase; 
