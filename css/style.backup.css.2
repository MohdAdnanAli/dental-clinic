.footer-links a:hover { color: var(--gold); }

.footer-bottom { 
  display: flex; 
  flex-wrap: wrap; 
  justify-content: space-between; 
  align-items: center; 
  padding-top: var(--space-lg); 
  border-top: 1px solid var(--border); 
  font-size: 0.85rem; 
  gap: var(--space-sm);
