/* FLOATING ELEMENTS */
.whatsapp-float { 
  position: fixed; 
  bottom: var(--space-lg); 
  right: var(--space-lg); 
  width: 4rem; 
  height: 4rem; 
  border-radius: 50%; 
  background: linear-gradient(145deg, #25D366, #20b858); 
  color: var(--white); 
  font-size: 1.5rem; 
  box-shadow: var(--shadow-md), 
    0 0 12px rgba(37, 211, 102, 0.5),
    0 0 24px rgba(37, 211, 102, 0.25);
  display: flex; 
  align-items: center; 
  justify-content: center; 
  text-decoration: none; 
  transition: var(--transition); 
  z-index: 100; 
  animation: subtleGreenGlow 3s ease-in-out infinite alternate;
}

@keyframes subtleGreenGlow {
  from { 
    box-shadow: var(--shadow-md), 
      0 0 12px rgba(37, 211, 102, 0.5),
      0 0 24px rgba(37, 211, 102, 0.25); 
  }
