  transform: translateY(-0.25rem); 
  box-shadow: var(--shadow-gold);
}

.btn-outline { 
  background: transparent; 
  color: var(--white); 
  border: 2px solid var(--gold); 
}

.btn-outline:hover { 
  background: var(--gold); 
