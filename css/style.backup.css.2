 /* TRIDENT Enhanced Styles - Premium Dental Theme | Mobile-First Optimized Spacing | UI/UX Focus */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Outfit:wght@300;400;500;600&display=swap');

/* SPACING SYSTEM - Mobile-First Scale */
:root {
  --space-xxs: 0.375rem;
  --space-xs: 0.75rem;
  --space-sm: 1.25rem;
  --space-md: 2rem;
  --space-lg: 3rem;
  --space-xl: 4.5rem;
  --space-2xl: 5.5rem;
  --space-3xl: 7rem;
  --space-4xl: 9rem;
  --space-5xl: 11rem;
  --container-padding: 6%;
  --grid-gap: var(--space-2xl);
  --section-gap: var(--space-5xl);

  --navy: #0b1f3a;
  --navy-mid: #132d52;
  --navy-light: #1e406e;
  --gold: #b8944a;
  --gold-dark: #9f7e3d;
  --gold-light: #e2c87e;
  --gold-glow: rgba(201,168,92,0.4);
  --cream: #faf8f4;
  --white: #ffffff;
  --text-dark: #1a1a2e;
  --text-muted: #6b7480;
  --surface: #f4f1eb;
  --border: rgba(201,168,92,0.25);
  --shadow-sm: 0 4px 12px rgba(0,0,0,0.08);
  --shadow-md: 0 12px 32px rgba(0,0,0,0.12);
  --shadow-gold: 0 8px 24px var(--gold-glow);
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* MOBILE-FIRST BASE - Zero Defaults */
*, *::before, *::after { 
  box-sizing: border-box; 
  margin: 0; 
  padding: 0; 
}

html { 
  scroll-behavior: smooth; 
  font-size: 16px; /* Base for clamp() */
  scroll-padding-top: 8rem; /* Account for fixed nav */
}

body { 
  font-family: 'Outfit', sans-serif; 
  background: var(--cream); 
  color: var(--text-dark); 
  line-height: 1.7; 
  font-size: clamp(1rem, 2.5vw, 1.1rem);
  overflow-x: hidden; 
  -webkit-font-smoothing: antialiased;
  -webkit-text-size-adjust: 100%;
}

p, .service-desc, .review-text, .section-subtitle { 
  font-family: 'Outfit', sans-serif;
  font-size: clamp(0.95rem, 2vw, 1.05rem); 
  line-height: 1.75; 
  color: var(--text-dark); 
  margin-bottom: var(--space-lg);
  text-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

.hero-doctor, .nav-text-sub, .stat-label { 
  font-family: 'Outfit', sans-serif;
  font-weight: 500; 
  letter-spacing: 0.5px; 
  color: var(--gold-light); 
}

/* TOUCH-FRIENDLY & ACCESSIBILITY */
a, button, label, [tabindex="0"] { 
  -webkit-tap-highlight-color: transparent; 
  touch-action: manipulation;
  min-height: 3rem; /* WCAG touch target */
}

button { 
  font-family: inherit; 
  cursor: pointer; 
  border: none;
}

img, video, iframe { 
  max-width: 100%; 
  height: auto; 
  display: block;
  border-radius: 1rem;
  box-shadow: var(--shadow-md);
  transition: var(--transition);
}

img:hover { 
  transform: translateY(-0.25rem) scale(1.02); 
  box-shadow: 0 20px 40px var(--gold-glow);
}

img { border-radius: clamp(0.5rem, 2vw, 1.25rem); }

/* CONTAINER & SECTIONS - Optimized Rhythm */
.container { 
  max-width: 1200px; 
  margin: 0 auto; 
  padding: 0 var(--container-padding);
}

.section { 
  padding: var(--space-5xl) var(--container-padding); 
  background: var(--cream);
  scroll-margin-top: 12rem;
  color: rgba(255,255,255,0.97);
}

.section.light-bg {
  color: var(--text-dark);
}

.light-bg-title {
  background: none !important;
  -webkit-background-clip: initial !important;
  -webkit-text-fill-color: var(--navy) !important;
  color: var(--navy) !important;
  text-shadow: none;
}


.main {
  scroll-padding-top: 12rem;
}

.section h1, .section h2, .section h3 {
  color: var(--white);
}

.section p, .section .service-desc {
  color: rgba(255,255,255,0.95);
}

/* NAV - Consistent, Fixed Mobile-First */
nav { 
  position: fixed; 
  top: 0; 
  width: 100%; 
  z-index: 1000; 
  background: rgba(11,31,58,0.98); 
  backdrop-filter: blur(20px); 
  border-bottom: 1px solid var(--border); 
  padding: var(--space-sm) var(--container-padding);
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  gap: var(--space-sm);
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

nav.glass {
  background: rgba(11,31,58,0.8);
  backdrop-filter: blur(40px) brightness(1.1);
  border-bottom: 1px solid var(--border);
  box-shadow: 0 8px 32px rgba(11,31,58,0.4);
}

nav.glass .nav-text-main {
  color: var(--white);
}

nav.glass .nav-text-sub {
  color: var(--gold);
}

nav.glass .nav-links a {
  color: rgba(255,255,255,0.95);
}

nav.glass .nav-links a:hover,
nav.glass .nav-links a.active {
  color: var(--gold-light);
}

nav.glass .nav-cta {
  background: var(--gold);
  color: var(--navy);
}

.nav-brand { 
  display: flex; 
  align-items: center; 
  gap: var(--space-md); 
  text-decoration: none;
}

.nav-text-main { 
  font-family: 'Cormorant Garamond', serif; 
  font-weight: 600; 
  font-size: clamp(1rem, 3vw, 1.15rem); 
  color: var(--white); 
  letter-spacing: 1px; 
}

.nav-text-sub { 
  font-size: 0.7rem; 
  color: var(--gold); 
  letter-spacing: 2px; 
  text-transform: uppercase; 
}

.nav-avatar { 
  width: 3rem; 
  height: 3rem; 
  border-radius: 50%; 
  object-fit: cover; 
  border: 2px solid rgba(255,255,255,0.4); 
  box-shadow: var(--shadow-sm);
}

.hamburger { 
  display: block; 
  background: none; 
  color: var(--white); 
  font-size: 1.5rem; 
  cursor: pointer; 
  padding: var(--space-xs); 
  width: 3rem; 
  height: 3rem; 
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.2);
}

.nav-links { 
  display: none; 
  list-style: none; 
  gap: var(--space-lg); 
  margin: 0;
  padding: var(--space-lg) var(--container-padding);
  background: rgba(11,31,58,0.98);
  position: fixed;
  top: 100%;
  left: 0;
  right: 0;
}

.nav-links.active { display: flex; flex-direction: column; }

.nav-links a { 
  color: rgba(255,255,255,0.9); 
  text-decoration: none; 
  font-size: 1rem; 
  font-weight: 500; 
  padding: var(--space-sm) 0; 
  border-bottom: 1px solid transparent;
  transition: var(--transition);
  position: relative;
}

.nav-links a.active,
.nav-links a:hover { 
  color: var(--gold); 
  border-color: var(--gold); 
}

.nav-links a.active::after { 
  content: ''; 
  position: absolute; 
  bottom: -0.25rem; 
  left: 0; 
  width: 100%; 
  height: 2px; 
  background: var(--gold); 
  box-shadow: 0 2px 8px var(--gold-glow);
}

.nav-links a:hover { color: var(--gold); border-color: var(--gold); }

.nav-cta { 
  background: var(--gold); 
  color: var(--navy); 
  padding: var(--space-xs) var(--space-lg); 
  border-radius: 0.375rem; 
  font-size: 0.85rem; 
  font-weight: 600; 
  letter-spacing: 1px; 
  text-transform: uppercase; 
  text-decoration: none; 
  transition: var(--transition);
  display: none; /* Mobile hidden */
  white-space: nowrap;
}

.nav-cta:hover { 
  background: var(--gold-light); 
  transform: translateY(-0.125rem);
}

/* HERO - Full Viewport Breathing Room */
.hero {
  min-height: 110vh; 
  position: relative; 
  background: linear-gradient(135deg, var(--navy), var(--navy-mid), var(--navy-light));
  display: flex; 
  align-items: center; 
  overflow: hidden;
  overflow-x: hidden;
  perspective: 1px;
  padding: var(--space-3xl) var(--container-padding) var(--space-2xl);
  scroll-margin-top: 10rem;
}

.hero-bg-video {
  position: absolute;
  inset: 0;
  z-index: 1;
  overflow: hidden;
}

.hero-bg-video-el {
  width: 120%;
  height: 120%;
  object-fit: cover;
  object-position: center;
  opacity: 0.15;
}

.hero-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) transparent 80%);
  z-index: 2;
}

.video-volume-toggle {
  position: absolute;
  bottom: 2rem;
  right: 2rem;
  background: rgba(255,255,255,0.2);
  border: 1px solid rgba(255,255,255,0.4);
  color: var(--white);
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 50%;
  font-size: 1.2rem;
  cursor: pointer;
  z-index: 4;
  backdrop-filter: blur(20px);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-volume-toggle:hover {
  background: rgba(255,255,255,0.3);
  transform: scale(1.1);
}

.hero-content {
  position: relative;
  z-index: 5;
}


.hero-bg-pattern { 
  position: fixed; 
  inset: 0; 
  background-size: cover !important; 
  background-position: center !important; 
  background-repeat: no-repeat !important;
  opacity: 0.22;
  z-index: -1 !important; 
  will-change: transform !important;
  width: 100vw;
  height: 100vh;
  top: 0;
  left: 0;
  transform: translateZ(-1px) scale(1.3);
}

.hero-content { 
  position: relative; 
  z-index: 2; 
  display: grid; 
  grid-template-columns: 1fr; 
  gap: var(--space-xl); 
  text-align: center; 
  max-width: 100%; 
}

.hero-badge { 
  display: inline-flex; 
  align-items: center; 
  gap: var(--space-xs); 
  background: rgba(201,168,92,0.15); 
  border: 1px solid var(--gold-glow); 
  color: var(--gold); 
  padding: var(--space-sm) var(--space-md); 
  border-radius: 1.5rem; 
  font-size: 0.8rem; 
  letter-spacing: 2px; 
  text-transform: uppercase; 
  margin-bottom: var(--space-sm);
  max-width: fit-content;
}

.hero-title { 
  font-weight: 300; 
  color: var(--white); 
  line-height: 1.1; 
  margin-bottom: var(--space-xs);
}

.hero-title span { color: var(--gold); font-style: italic; }

.hero-hindi { 
  font-size: 1rem; 
  color: rgba(255,255,255,0.7); 
  letter-spacing: 1px; 
  margin: var(--space-sm) 0 var(--space-md); 
}

.hero-doctor { 
  font-size: 1rem; 
  color: var(--gold-light); 
  font-weight: 500; 
  margin-bottom: var(--space-lg); 
}

.hero-stars, .stars, .review-stars { 
  color: #FFD700 !important; /* Brighter golden yellow */
}

.hero-stars { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  gap: var(--space-md); 
  margin-bottom: var(--space-lg); 
}

.hero-rating { 
  color: var(--white); 
  font-size: 1.3rem; 
  font-weight: 600; 
  font-family: 'Cormorant Garamond', serif; 
}

/* BUTTONS - Touch-Friendly Scale */
.hero-actions { 
  display: flex; 
  flex-direction: column; 
  gap: var(--space-md); 
  align-items: center; 
}

.btn-primary, .btn-outline { 
  padding: var(--space-sm) var(--space-xl); 
  border-radius: 0.5rem; 
  font-size: 0.9rem; 
  font-weight: 600; 
  letter-spacing: 1px; 
  text-transform: uppercase; 
  cursor: pointer; 
  text-decoration: none; 
  transition: var(--transition); 
  display: inline-flex; 
  align-items: center; 
  gap: var(--space-xs); 
  min-height: 3rem; 
  width: 100%; 
  max-width: 18rem; 
  justify-content: center;
  font-family: 'Outfit', sans-serif;
}

.btn-primary { 
  background: var(--gold); 
  color: var(--navy); 
  box-shadow: var(--shadow-sm); 
}

.btn-primary:hover { 
  background: var(--gold-dark); 
  transform: translateY(-0.25rem); 
  box-shadow: var(--shadow-gold);
}

.btn-outline { 
  background: transparent; 
  color: var(--white); 
  border: 2px solid var(--gold); 
}

.btn-outline:hover { 
  background: var(--gold); 
  color: var(--navy); 
}

/* STATS BAR */
.stats-bar { 
  display: flex; 
  gap: var(--space-xl); 
  justify-content: center; 
  padding: var(--space-xl) var(--container-padding); 
  background: rgba(250,248,244,0.95); 
  flex-wrap: wrap; 
  border-bottom: 1px solid var(--border);
}

.stat-item { text-align: center; min-width: 5rem; }

.stat-num { 
  font-size: clamp(2rem, 8vw, 3.5rem); 
  font-weight: 300; 
  font-family: 'Cormorant Garamond', serif; 
  color: var(--navy); 
  line-height: 1; 
  margin-bottom: var(--space-xs);
}

.stat-label { 
  font-size: 0.85rem; 
  color: var(--text-muted); 
  letter-spacing: 1px; 
  text-transform: uppercase; 
}

/* SECTION HEADERS */
.section-header { 
  text-align: center; 
  margin-bottom: var(--space-2xl);
}

.section-eyebrow { 
  display: inline-block; 
  background: var(--gold); 
  color: var(--navy); 
  padding: var(--space-xs) var(--space-md); 
  border-radius: 1.5rem; 
  font-size: 0.8rem; 
  font-weight: 600; 
  letter-spacing: 2px; 
  text-transform: uppercase; 
  margin-bottom: var(--space-sm);
}

h1, h2, h3, h4, h5, h6 { 
  font-family: 'Cormorant Garamond', serif; 
  font-weight: 300; 
  line-height: 1.2; 
  margin-block: var(--space-lg);
  letter-spacing: -0.025em;
}

h1, h2 { 
  background: linear-gradient(135deg, var(--white) 0%, var(--gold) 60%, var(--gold-light) 100%); 
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 400;
  text-shadow: 0 2px 8px rgba(255,255,255,0.3);
}

.hero-title, .section-title {
  color: var(--white) !important;
  -webkit-text-fill-color: var(--white) !important;
}

.section-title:not(.hero-title):not(.light-bg-title), h2:not(.hero h2), h3:not(.hero *), h4:not(.hero *) { 
  color: var(--gold) !important; 
  -webkit-text-fill-color: var(--gold) !important;
}

h5, h6 { color: var(--navy-light); font-weight: 400; }

h1 { font-size: clamp(2.2rem, 8vw, 4rem); }
h2 { font-size: clamp(2rem, 5vw, 3.5rem); }
h3 { font-size: clamp(1.75rem, 4vw, 2.75rem); }
h4 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); }
h5 { font-size: clamp(1.25rem, 3vw, 1.875rem); }
h6 { font-size: clamp(1.125rem, 2.5vw, 1.5rem); }

.section-title em { color: var(--gold); font-style: italic; }

.section-subtitle { 
  max-width: 36rem; 
  margin: 0 auto; 
  color: var(--text-muted); 
  font-size: 1.1rem; 
  line-height: 1.6; 
}

/* SERVICES GRID */
.services-section { 
  padding: var(--section-gap) var(--container-padding); 
  background: var(--cream); 
}

.services-grid { 
  display: grid; 
  grid-template-columns: 1fr; 
  gap: var(--grid-gap); 
  max-width: 80rem; 
  margin: var(--space-xl) auto; 
}

.service-card { 
  perspective: 1200px; 
  height: 28rem; 
  position: relative;
}

.service-inner { 
  position: relative; 
  width: 100%; 
  height: 100%; 
  transition: transform 0.8s; 
  transform-style: preserve-3d; 
}

.service-card:hover .service-inner { transform: rotateY(180deg); }

.service-front, .service-back { 
  position: absolute; 
  width: 100%; 
  height: 100%; 
  backface-visibility: hidden; 
  background: var(--white); 
  border-radius: 1.25rem; 
  padding: var(--space-2xl) var(--space-xl); 
  text-align: center; 
  box-shadow: var(--shadow-md); 
  border: 1px solid var(--border);
  display: flex; 
  flex-direction: column; 
  justify-content: center; 
  gap: var(--space-lg);
  margin: var(--space-lg);
}

.service-back { 
  transform: rotateY(180deg); 
  background: linear-gradient(135deg, var(--navy), var(--navy-mid)); 
  color: var(--white); 
}

.service-back .service-name,
.service-back p,
.service-back .btn-primary {
  color: var(--white) !important;
}

.service-num { 
  position: absolute; 
  top: -1rem; 
  left: var(--space-lg); 
  background: var(--gold); 
  color: var(--navy); 
  width: 3rem; 
  height: 3rem; 
  border-radius: 50%; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  font-weight: 600; 
  font-size: 1rem; 
  box-shadow: var(--shadow-gold);
}

.service-icon { 
  font-size: 3.5rem; 
  margin-bottom: var(--space-md); 
}

.service-name { 
  font-size: 1.4rem; 
  font-weight: 600; 
  color: var(--navy); 
  margin-bottom: var(--space-sm); 
  letter-spacing: 0.5px; 
}

.service-desc { 
  color: var(--text-muted); 
  flex-grow: 1; 
  font-size: 0.95rem;
}

/* REVIEWS & CARDS */
.review-card { 
  background: var(--white); 
  padding: var(--space-2xl) var(--space-xl); 
  border-radius: 1.75rem; 
  box-shadow: var(--shadow-md); 
  border: 1px solid var(--border);
  gap: var(--space-xl);
  margin: var(--space-lg) 0;
}

.review-text { 
  font-size: 1.1rem; 
  line-height: 1.6; 
  font-style: italic; 
  margin-bottom: var(--space-lg); 
}

.review-footer { 
  display: flex; 
  gap: var(--space-lg); 
  align-items: center; 
}

.review-avatar { 
  width: 3rem; 
  height: 3rem; 
  border-radius: 50%; 
  background: var(--gold); 
  color: var(--navy); 
  font-weight: 600; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
}

/* GALLERY, CONTACT, FORMS - Consistent */
.gallery-grid { 
  display: grid; 
  grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); 
  gap: var(--grid-gap); 
}

.booking-form { 
  display: flex; 
  flex-direction: column; 
  gap: var(--space-lg); 
}

.booking-form input, 
.booking-form select, 
.booking-form textarea { 
  padding: var(--space-md); 
  border: 2px solid #e5e5e5; 
  border-radius: 0.75rem; 
  font-size: 1rem; 
  transition: var(--transition); 
  background: var(--white);
  min-height: 3rem;
}

.booking-form input:focus, 
.booking-form select:focus, 
.booking-form textarea:focus { 
  outline: 2px solid var(--gold); 
  outline-offset: 2px; 
  border-color: var(--gold);
}

/* FOOTER */
footer { 
  background: var(--navy); 
  color: var(--white); 
  padding: var(--space-2xl) var(--container-padding) var(--space-lg); 
}

.footer-top { 
  display: grid; 
  grid-template-columns: 1fr; 
  gap: var(--space-xl); 
  margin-bottom: var(--space-xl); 
}

.footer-links { 
  display: flex; 
  flex-wrap: wrap; 
  gap: var(--space-md); 
  font-size: 0.9rem; 
}

.footer-links a { 
  color: rgba(255,255,255,0.7); 
  text-decoration: none; 
  transition: var(--transition); 
}

.footer-links a:hover { color: var(--gold); }

.footer-bottom { 
  display: flex; 
  flex-wrap: wrap; 
  justify-content: space-between; 
  align-items: center; 
  padding-top: var(--space-lg); 
  border-top: 1px solid var(--border); 
  font-size: 0.85rem; 
  gap: var(--space-sm);
}

/* FLOATING ELEMENTS */
.whatsapp-float { 
  position: fixed; 
  bottom: var(--space-lg); 
  right: var(--space-lg); 
  width: 4rem; 
  height: 4rem; 
  border-radius: 50%; 
  background: linear-gradient(145deg, #25D366, #20b858); 
  color: var(--white); 
  font-size: 1.5rem; 
  box-shadow: var(--shadow-md), 
    0 0 12px rgba(37, 211, 102, 0.5),
    0 0 24px rgba(37, 211, 102, 0.25);
  display: flex; 
  align-items: center; 
  justify-content: center; 
  text-decoration: none; 
  transition: var(--transition); 
  z-index: 100; 
  animation: subtleGreenGlow 3s ease-in-out infinite alternate;
}

@keyframes subtleGreenGlow {
  from { 
    box-shadow: var(--shadow-md), 
      0 0 12px rgba(37, 211, 102, 0.5),
      0 0 24px rgba(37, 211, 102, 0.25); 
  }
  to { 
    box-shadow: var(--shadow-md), 
      0 0 20px rgba(37, 211, 102, 0.7), 
      0 0 32px rgba(37, 211, 102, 0.4); 
  }
}

.whatsapp-float:hover { 
  transform: scale(1.12); 
  animation-play-state: paused;
}


/* ANIMATIONS & UTILITIES */
.fade-in { 
  opacity: 0; 
  transform: translateY(var(--space-md)); 
  animation: fadeInUp 0.8s ease forwards; 
}

@keyframes fadeInUp { 
  to { opacity: 1; transform: translateY(0); } 
}

/* Mobile Headroom & Breathing */
@media (max-width: 768px) {
  .section, .services-section, .hero {
    padding-top: var(--space-5xl) !important;
    padding-bottom: var(--space-4xl) !important;
  }
  .services-grid, .gallery-grid, .reviews-grid {
    gap: var(--space-xl);
    margin: var(--space-2xl) 0;
  }
  .service-card, .review-card {
    margin: var(--space-lg) 0;
  }
}

/* RESPONSIVE - Enhanced Spacing Scale */
@media (min-width: 768px) { 
  .hamburger { display: none; } 
  .nav-links { 
    display: flex; 
    flex-direction: row; 
    position: static; 
    background: none; 
    padding: 0; 
    top: auto;
  }
  .nav-cta { display: inline-flex; }
